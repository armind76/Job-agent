# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn credentials (for Playwright login)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# Indeed credentials (optional, for saved jobs)
INDEED_EMAIL=your@email.com
INDEED_PASSWORD=yourpassword

# Glassdoor credentials
GLASSDOOR_EMAIL=your@email.com
GLASSDOOR_PASSWORD=yourpassword

# User profile info (used in cover letters / forms)
USER_FULL_NAME="Your Name"
USER_EMAIL=your@email.com
USER_PHONE=+1-555-000-0000
USER_LOCATION="New York, NY"
USER_LINKEDIN_URL=https://linkedin.com/in/yourprofile
USER_GITHUB_URL=https://github.com/yourhandle
USER_PORTFOLIO_URL=

# Database path (relative to project root)
DB_PATH=data/jobs.db

# Resume directory
RESUME_DIR=data/resumes
